# ── Network ───────────────────────────────────────────────────────────────────
CHAIN_ID=                         # Base Sepolia (examples 01, 02, 03)
RECOVERY_SERVICE_URL=             # Candide Recovery Service URL (01, 02, 03)
NODE_URL=                         # RPC node URL (01, 03)

# ── Bundler / Paymaster ───────────────────────────────────────────────────────
# Required by Example 01 only (deploys the Safe)
BUNDLER_URL=
PAYMASTER_URL=
SPONSORSHIP_POLICY_ID=

# ── Owner ─────────────────────────────────────────────────────────────────────
# Optionally leave blank on first run — Example 01 generates and prints it for you.
# Fill in after running Example 01 so Examples 02 and 03 can reuse it.
OWNER_PRIVATE_KEY=

# ── Safe account ──────────────────────────────────────────────────────────────
# Fill in after running Example 01. For # (02, 03)
SAFE_ACCOUNT_ADDRESS=             

# ── Contact details ───────────────────────────────────────────────────────────
USER_EMAIL=                       # Email for recovery channels and alerts (01, 02, 03)
USER_PHONE=                       # Phone with country code, e.g. +1234567890 — optional for SMS (01, 02)